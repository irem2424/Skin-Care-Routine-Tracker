import { useLanguage } from "../lib/LanguageContext";
import { Button } from "./ui/button";

export default function LanguageSelector({ onSelect }: { onSelect?: () => void }) {
  const { setLanguage } = useLanguage();

  const handleSelect = async (lang: "en" | "tr") => {
    await setLanguage(lang);
    if (onSelect) onSelect();
  };

  return (
    <div className="flex flex-col items-center justify-center min-h-screen p-6 bg-[#fbfaf7]">
      <h1 className="text-3xl font-serif text-[#3c3c3c] mb-6">Choose Your Language</h1>
      <div className="flex gap-4">
        <Button onClick={() => handleSelect('en')} className="w-32 h-14 bg-white text-[#4a5043] border border-[#e5e2d9] hover:bg-[#f5f5f0] shadow-sm text-lg rounded-xl">English</Button>
        <Button onClick={() => handleSelect('tr')} className="w-32 h-14 bg-white text-[#4a5043] border border-[#e5e2d9] hover:bg-[#f5f5f0] shadow-sm text-lg rounded-xl">Türkçe</Button>
      </div>
    </div>
  );
}
